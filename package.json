{
  "name": "multiple-choice-questions",
  "version": "1.0.0",
  "description": "Doktorlar ve tıp öğrencileri için lokal çalışan, JSON tabanlı çoktan seçmeli test uygulaması.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dist": "npm run build",
    "preview": "vite preview",
    "web": "npm run dev",
    "serve:dist": "npm run preview -- --host 127.0.0.1 --port 4173 --strictPort",
    "tauri": "node ./tools/tauri-cli.mjs",
    "build:desktop": "node ./tools/build-desktop.mjs",
    "release": "node ./tools/run-pwsh-script.mjs ./tools/build-release.ps1 -NoLegacyCopy",
    "release:no-legacy": "node ./tools/run-pwsh-script.mjs ./tools/build-release.ps1 -NoLegacyCopy",
    "release:dry-run": "node ./tools/run-pwsh-script.mjs ./tools/build-release.ps1 -NoLegacyCopy -DryRun",
    "release:with-legacy": "node ./tools/run-pwsh-script.mjs ./tools/build-release.ps1",
    "backup:cloud-user": "node ./tools/backup-cloud-user.mjs",
    "backup:supabase": "node ./tools/run-pwsh-script.mjs ./tools/backup-supabase.ps1",
    "backup:supabase:dry": "node ./tools/run-pwsh-script.mjs ./tools/backup-supabase.ps1 -DryRun",
    "validate:set": "node ./tools/validate-set.js",
    "validate:set:strict": "node ./tools/validate-set.js --require-files",
    "md2json": "node ./tools/md2json.js",
    "test:smoke": "node ./tools/run-smoke.js",
    "test:smoke:headed": "node ./tools/run-smoke.js --headed",
    "test:smoke:install": "npx playwright install chromium",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test": "npm run test:smoke && npm run test:unit",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asklepioszealot/multiple-choice-questions.git"
  },
  "keywords": [
    "multiple-choice",
    "quiz",
    "study",
    "medical"
  ],
  "author": "AsklepiosZealot",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/asklepioszealot/multiple-choice-questions/issues"
  },
  "homepage": "https://github.com/asklepioszealot/multiple-choice-questions#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "jsdom": "^29.0.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "dompurify": "^3.3.3",
    "fflate": "^0.8.2",
    "sql.js": "^1.14.1"
  }
}
