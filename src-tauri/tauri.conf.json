{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Çoktan Seçmeli Sorular",
  "version": "0.1.0",
  "identifier": "com.asklepioszealot.multiplechoicestest",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Çoktan Seçmeli Sorular",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGQzVBODFGOUVEOTE0REUKUldUZUZObWVINmpGTC95ZTFoVksvcytjcGVSTkJ6NUtUdUFHK05LdTN0MEZ6YTc5bU8xaCtzRjUK",
      "endpoints": [
        "https://github.com/asklepioszealot/multiple-choice-questions/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
